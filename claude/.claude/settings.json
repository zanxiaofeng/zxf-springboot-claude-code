{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mvn clean verify)",
      "Bash(mvn test)",
      "Bash(mvn compile)",
      "Bash(mvn spring-boot:run)",
      "Bash(mvn flyway:*)",
      "Bash(./scripts/run-contract-tests.sh)",
      "Bash(./scripts/fast-test.sh)",
      "Bash(./scripts/full-ci.sh)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -f *)",
      "Bash(git clean *)",
      "Bash(git stash drop *)",
      "Bash(mvn deploy *)",
      "Bash(mvn release:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*secret*)",
      "Read(**/application-prod.yml)",
      "Read(**/application-prod.properties)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "mvn compile -q 2>&1 | tail -5",
            "timeout": 30000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mvn test -q 2>&1 | tail -10",
            "timeout": 120000
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": true,
  "includeGitInstructions": true,
  "effortLevel": "high",
  "language": "zh-CN",
  "env": {
    "JAVA_HOME": "/home/davis/.jdks/ms-21"
  }
}
