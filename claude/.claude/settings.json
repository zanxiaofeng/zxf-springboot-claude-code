{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mvn clean verify)",
      "Bash(mvn test)",
      "Bash(mvn compile)",
      "Bash(mvn spring-boot:run)",
      "Bash(mvn flyway:*)",
      "Bash(./scripts/run-contract-tests.sh)",
      "Bash(./scripts/run-integration-tests.sh)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -f *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*secret*)",
      "Read(**/application-prod.yml)",
      "Read(**/application-prod.properties)"
    ]
  },
  "autoMemoryEnabled": true,
  "includeGitInstructions": true,
  "effortLevel": "high"
}
