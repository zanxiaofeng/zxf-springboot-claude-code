pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: p15-title
    elementType: text
    bounds: [60, 30, 900, 42]
    content:
      style: "$heading"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>CI/CD Pipeline：分层质量门禁</strong></p>
  - elementId: p15-line
    elementType: shape
    bounds: [60, 78, 1160, 2]
    shapeName: rect
    fill:
      type: solid
      color: "$border"
  - elementId: p15-pipeline-title
    elementType: text
    bounds: [60, 95, 400, 30]
    content:
      style: "$subheading"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>GitHub Actions 四阶段流水线</strong></p>
  - elementId: p15-stage1-bg
    elementType: shape
    bounds: [60, 140, 250, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
  - elementId: p15-stage1-text
    elementType: text
    bounds: [60, 140, 250, 100]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Unit Tests</strong></p>
        <p><span style="font-size:13px;">mvn test -Dtest="*Test"</span></p>
  - elementId: p15-arrow1
    elementType: shape
    bounds: [315, 185, 30, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border: {style: solid, width: 2, color: "$secondary"}
  - elementId: p15-stage2-bg
    elementType: shape
    bounds: [350, 140, 250, 100]
    shapeName: rect
    fill:
      type: solid
      color: "#047857"
  - elementId: p15-stage2-text
    elementType: text
    bounds: [350, 140, 250, 100]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Contract Tests</strong></p>
        <p><span style="font-size:13px;">mvn verify -Pcontract-tests</span></p>
  - elementId: p15-arrow2
    elementType: shape
    bounds: [605, 185, 30, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border: {style: solid, width: 2, color: "$secondary"}
  - elementId: p15-stage3-bg
    elementType: shape
    bounds: [640, 140, 250, 100]
    shapeName: rect
    fill:
      type: solid
      color: "#059669"
  - elementId: p15-stage3-text
    elementType: text
    bounds: [640, 140, 250, 100]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Integration Tests</strong></p>
        <p><span style="font-size:13px;">mvn test -Dtest="*IT"</span></p>
  - elementId: p15-arrow3
    elementType: shape
    bounds: [895, 185, 30, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border: {style: solid, width: 2, color: "$secondary"}
  - elementId: p15-stage4-bg
    elementType: shape
    bounds: [930, 140, 250, 100]
    shapeName: rect
    fill:
      type: solid
      color: "#10B981"
  - elementId: p15-stage4-text
    elementType: text
    bounds: [930, 140, 250, 100]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Publish Stubs</strong></p>
        <p><span style="font-size:13px;">main only, mvn deploy</span></p>
  - elementId: p15-detail-title
    elementType: text
    bounds: [60, 270, 400, 32]
    content:
      style: "$subheading"
      fontSize: 20
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Maven Profile 与本地脚本</strong></p>
  - elementId: p15-detail-left-bg
    elementType: shape
    bounds: [60, 315, 560, 330]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"
    border:
      style: solid
      width: 1
      color: "$border"
  - elementId: p15-detail-left-text
    elementType: text
    bounds: [80, 330, 520, 300]
    content:
      style: "$body"
      fontSize: 15
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><strong style="color:$primary;">contract-tests Profile</strong></p>
        <p>· spring-cloud-contract-maven-plugin</p>
        <p>· generateTests → generate-test-sources 阶段</p>
        <p>· runTests → test 阶段</p>
        <p style="margin-top:8px"><strong style="color:$primary;">fast-test Profile</strong></p>
        <p>· spring.cloud.contract.verifier.skip=true</p>
        <p>· 用于快速本地验证，跳过契约测试</p>
  - elementId: p15-detail-right-bg
    elementType: shape
    bounds: [640, 315, 560, 330]
    shapeName: rect
    fill:
      type: solid
      color: "$lightBg"
    border:
      style: solid
      width: 1
      color: "#A7F3D0"
  - elementId: p15-detail-right-text
    elementType: text
    bounds: [660, 330, 520, 300]
    content:
      style: "$body"
      fontSize: 15
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><strong style="color:$primary;">本地脚本工具</strong></p>
        <p style="margin-top:6px"><span style="color:$primary;">fast-test.sh</span></p>
        <p>mvn clean test -Pfast-test</p>
        <p style="margin-top:8px"><span style="color:$primary;">full-ci.sh</span></p>
        <p>1. mvn clean</p>
        <p>2. mvn compile</p>
        <p>3. mvn test -Dtest="*Test"</p>
        <p>4. mvn verify -Pcontract-tests</p>
        <p>5. mvn test -Dtest="*IT"</p>
  - elementId: p15-page-num
    elementType: text
    bounds: [1160, 690, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: "15"