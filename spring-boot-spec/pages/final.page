pageType: final
background:
  type: image
  src: "/mnt/agents/output/spring-boot-spec/images/6_Minimalist_Matrix_Green_Abstract.png"
  fit: {mode: cover}
  mask:
    type: gradient
    gradientType: linear
    angle: 90
    stops:
      - {position: 0, color: "#0F172AE6"}
      - {position: 0.5, color: "#0F172AB3"}
      - {position: 1, color: "#0F172AE6"}
elements:
  - elementId: final-title
    elementType: text
    bounds: [140, 200, 1000, 70]
    content:
      style: "$title"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>规范即代码，文档即契约</strong></p>
  - elementId: final-line
    elementType: shape
    bounds: [540, 285, 200, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
  - elementId: final-points
    elementType: text
    bounds: [190, 310, 900, 180]
    content:
      fontSize: 20
      color: "#CBD5E1"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.8
      align: [center, top]
      text: |
        <p>· 结构化目录支撑规模化协作</p>
        <p>· TDD + Contract Test 保障 API 契约一致性</p>
        <p>· Flyway + CI/CD 实现可重复交付</p>
        <p>· Claude Code 上下文注入确保 AI Coding 规范一致性</p>
  - elementId: final-note
    elementType: text
    bounds: [190, 510, 900, 80]
    content:
      fontSize: 14
      color: "#94A3B8"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.5
      align: [center, top]
      text: |
        <p>本文档由 Claude Code 根据项目结构自动生成并维护</p>
        <p>修改规范时同步更新 .claude/skills/ 与 docs/conventions/ 下对应文件</p>
  - elementId: final-bottom-bar
    elementType: shape
    bounds: [0, 700, 1280, 20]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
  - elementId: final-page-num
    elementType: text
    bounds: [1160, 672, 60, 20]
    content:
      fontSize: 14
      color: "#FFFFFF80"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [right, middle]
      wrap: false
      text: "16"