pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: p11-title
    elementType: text
    bounds: [60, 30, 900, 42]
    content:
      style: "$heading"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Contract Test：契约即文档</strong></p>
  - elementId: p11-line
    elementType: shape
    bounds: [60, 78, 1160, 2]
    shapeName: rect
    fill:
      type: solid
      color: "$border"
  - elementId: p11-dir-title
    elementType: text
    bounds: [60, 95, 300, 30]
    content:
      style: "$subheading"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>目录与文件规范</strong></p>
  - elementId: p11-dir-bg
    elementType: shape
    bounds: [60, 135, 560, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$lightBg"
    border:
      style: solid
      width: 1
      color: "#A7F3D0"
  - elementId: p11-dir-text
    elementType: text
    bounds: [80, 150, 520, 170]
    content:
      style: "$body"
      fontSize: 14
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p><strong style="color:$primary;">src/test/resources/contracts/</strong></p>
        <p>├── users/</p>
        <p>│   ├── shouldCreateUser.groovy</p>
        <p>│   ├── shouldReturn404WhenUserNotFound.groovy</p>
        <p>│   └── shouldRejectInvalidCreateUser.groovy</p>
        <p>└── orders/ ...</p>
  - elementId: p11-dsl-title
    elementType: text
    bounds: [60, 355, 300, 30]
    content:
      style: "$subheading"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Groovy DSL 核心结构</strong></p>
  - elementId: p11-dsl-bg
    elementType: shape
    bounds: [60, 395, 560, 250]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"
    border:
      style: solid
      width: 1
      color: "$border"
  - elementId: p11-dsl-text
    elementType: text
    bounds: [80, 410, 520, 220]
    content:
      style: "$body"
      fontSize: 14
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p><strong>Contract.make</strong> {</p>
        <p>  request { method POST(); url '/api/v1/users' }</p>
        <p>  body([ username: 'john.doe', ... ])</p>
        <p>  response {</p>
        <p>    status 201</p>
        <p>    body([ id: $(regex(positiveInt())), ... ])</p>
        <p>  }</p>
        <p>}</p>
  - elementId: p11-check-title
    elementType: text
    bounds: [660, 95, 300, 30]
    content:
      style: "$subheading"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>强制检查清单</strong></p>
  - elementId: p11-check-bg
    elementType: shape
    bounds: [660, 135, 560, 510]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"
    border:
      style: solid
      width: 1
      color: "$border"
  - elementId: p11-check-text
    elementType: text
    bounds: [680, 150, 520, 480]
    content:
      style: "$body"
      fontSize: 15
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><span style="color:$primary;">1.</span> Request/Response 字段与 docs/design/api-spec-v1.md 一致</p>
        <p style="margin-top:6px"><span style="color:$primary;">2.</span> 使用 regex 匹配动态值：</p>
        <p>   · id → $(regex(positiveInt()))</p>
        <p>   · timestamp → $(regex(iso8601WithOffset()))</p>
        <p>   · email → 预定义格式匹配</p>
        <p style="margin-top:6px"><span style="color:$accent;">3.</span> <strong>错误场景 Contract 必须覆盖</strong>：</p>
        <p>   · 400 Bad Request（参数校验失败）</p>
        <p>   · 404 Not Found（资源不存在）</p>
        <p>   · 500 Internal Server Error（兜底）</p>
        <p style="margin-top:6px"><span style="color:$primary;">4.</span> 生成 Stub 后运行：</p>
        <p>   <span style="color:$primary;">./scripts/run-contract-tests.sh</span> 通过</p>
        <p style="margin-top:6px"><span style="color:$primary;">5.</span> ContractBaseTest 配置 RestAssuredMockMvc</p>
  - elementId: p11-page-num
    elementType: text
    bounds: [1160, 690, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: "11"