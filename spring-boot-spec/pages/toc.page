    elementType: text
    bounds: [60, 40, 400, 45]
    content:
      style: "$heading"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>目录</strong></p>
  - elementId: toc-line
    elementType: shape
    bounds: [60, 95, 1160, 2]
