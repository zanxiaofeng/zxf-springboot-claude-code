pageType: cover
background:
  type: image
  src: "/mnt/agents/output/spring-boot-spec/images/2_Green_tech_background_Images_Free.png"
  fit: {mode: cover}
  mask:
    type: gradient
    gradientType: linear
    angle: 90
    stops:
      - {position: 0, color: "#0F172AE6"}
      - {position: 0.5, color: "#0F172AB3"}
      - {position: 1, color: "#0F172AE6"}
elements:
  - elementId: cover-title
    elementType: text
    bounds: [140, 220, 1000, 130]
    content:
      style: "$title"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Spring Boot 3 REST API</strong></p>
        <p><strong>项目规范</strong></p>
  - elementId: cover-subtitle
    elementType: text
    bounds: [240, 370, 800, 40]
    content:
      fontSize: 22
      color: "#CBD5E1"
      fontFamily: "Liter, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>规范即代码 · 文档即契约</p>
  - elementId: cover-version
    elementType: text
    bounds: [240, 430, 800, 60]
    content:
      fontSize: 16
      color: "#94A3B8"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>版本 v1.0  |  适用：Claude Code AI Coding + Spring Boot 3.x + Java 21</p>
  - elementId: cover-accent-line
    elementType: shape
    bounds: [540, 360, 200, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
  - elementId: cover-bottom-bar
    elementType: shape
    bounds: [0, 700, 1280, 20]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"