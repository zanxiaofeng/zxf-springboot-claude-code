pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: p7-title
    elementType: text
    bounds: [60, 30, 900, 42]
    content:
      style: "$heading"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Java 与 Spring Boot 编码核心规范</strong></p>
  - elementId: p7-line
    elementType: shape
    bounds: [60, 78, 1160, 2]
    shapeName: rect
    fill:
      type: solid
      color: "$border"
  - elementId: p7-java-table
    elementType: table
    bounds: [60, 100, 560, 270]
    style: "$default"
    columnWidths: [0.35, 0.65]
    rowHeights: [0.14, 0.143, 0.143, 0.143, 0.143, 0.143, 0.143]
    rows:
      - - content: {text: "规则", fontSize: 15}
        - content: {text: "要求", fontSize: 15}
      - - content: {text: "命名", fontSize: 14}
        - content: {text: "类 PascalCase / 常量 UPPER_SNAKE / 其他 camelCase", fontSize: 14}
      - - content: {text: "注入方式", fontSize: 14}
        - content: {text: "构造器注入 + @RequiredArgsConstructor", fontSize: 14}
      - - content: {text: "空值处理", fontSize: 14}
        - content: {text: "返回 Optional<T>，禁止返回裸 null", fontSize: 14}
      - - content: {text: "日期时间", fontSize: 14}
        - content: {text: "使用 OffsetDateTime，禁止 Date / Calendar", fontSize: 14}
      - - content: {text: "集合返回", fontSize: 14}
        - content: {text: "不可变集合 List.of() / unmodifiableList()", fontSize: 14}
      - - content: {text: "异常", fontSize: 14}
        - content: {text: "业务异常继承 BusinessException", fontSize: 14}
  - elementId: p7-spring-table
    elementType: table
    bounds: [640, 100, 560, 270]
    style: "$default"
    columnWidths: [0.35, 0.65]
    rowHeights: [0.14, 0.143, 0.143, 0.143, 0.143, 0.143, 0.143]
    rows:
      - - content: {text: "规则", fontSize: 15}
        - content: {text: "要求", fontSize: 15}
      - - content: {text: "分层", fontSize: 14}
        - content: {text: "Domain → Application → Infrastructure → Interfaces", fontSize: 14}
      - - content: {text: "事务", fontSize: 14}
        - content: {text: "@Transactional 只放 Service 层，默认 readOnly = true", fontSize: 14}
      - - content: {text: "API 路径", fontSize: 14}
        - content: {text: "/api/v{version}/{resources}，复数名词", fontSize: 14}
      - - content: {text: "响应包装", fontSize: 14}
        - content: {text: "所有 Controller 返回 ApiResponse<T>", fontSize: 14}
      - - content: {text: "DTO", fontSize: 14}
        - content: {text: "使用 record 定义数据传输对象", fontSize: 14}
      - - content: {text: "Service", fontSize: 14}
        - content: {text: "使用 interface + impl 分离实现", fontSize: 14}
  - elementId: p7-output-title
    elementType: text
    bounds: [60, 395, 400, 32]
    content:
      style: "$subheading"
      fontSize: 20
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>输出规范</strong></p>
  - elementId: p7-output-bg
    elementType: shape
    bounds: [60, 440, 1160, 220]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"
    border:
      style: solid
      width: 1
      color: "$border"
  - elementId: p7-output-text
    elementType: text
    bounds: [80, 455, 1120, 190]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p>· 所有代码必须包含 JavaDoc</p>
        <p>· 测试类命名：<span style="color:$primary;">{ClassUnderTest}Test</span> / <span style="color:$primary;">{ClassUnderTest}IT</span> / <span style="color:$primary;">{ClassUnderTest}ContractTest</span></p>
        <p>· DTO 使用 record，Service 使用 interface + impl</p>
        <p>· 使用构造器注入，<span style="color:$accent;"><strong>禁止字段 @Autowired</strong></span></p>
        <p>· 禁止在 Controller 中写业务逻辑（四层分离）</p>
  - elementId: p7-page-num
    elementType: text
    bounds: [1160, 690, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: "07"