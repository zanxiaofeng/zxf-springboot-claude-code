{
  "version": "1.0",
  "project": {
    "name": "DemoProject",
    "type": "spring-boot-rest-api",
    "language": "java"
  },
  "context": {
    "auto_load": {
      "always": [
        ".claude/context/project-overview.md",
        ".claude/context/tech-stack.md"
      ],
      "conditional": {
        "file_patterns": {
          ".*Controller\\.java$": [
            ".claude/context/api-conventions.md",
            ".claude/skills/contract-test.md"
          ],
          ".*Service\\.java$": [
            ".claude/context/service-conventions.md"
          ],
          ".*Repository\\.java$": [
            ".claude/context/db-conventions.md"
          ],
          ".*Test\\.java$": [
            ".claude/context/test-conventions.md",
            ".claude/skills/tdd-workflow.md"
          ],
          ".*IT\\.java$": [
            ".claude/context/test-conventions.md"
          ],
          ".*Contract.*\\.groovy$": [
            ".claude/skills/contract-test.md"
          ],
          "V\\d+__.*\\.sql$": [
            ".claude/skills/db-migration.md"
          ]
        }
      }
    }
  },
  "skills": {
    "directory": ".claude/skills",
    "activation": {
      "tdd": {
        "keywords": ["implement", "develop", "new feature", "TDD", "test driven"],
        "files": [".claude/skills/tdd-workflow.md"]
      },
      "contract": {
        "keywords": ["API", "endpoint", "contract", "contract-test"],
        "files": [".claude/skills/contract-test.md"]
      },
      "database": {
        "keywords": ["database", "table", "migration", "flyway", "schema"],
        "files": [".claude/skills/db-migration.md"]
      }
    }
  }
}
